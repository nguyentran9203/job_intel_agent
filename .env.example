# Required
ANTHROPIC_API_KEY=sk-ant-...

# Greenhouse company board slugs (comma-separated, no spaces)
# Find the slug in: https://boards.greenhouse.io/{slug}
GREENHOUSE_SLUGS=intercom,hubspot,deliveryhero,zalando,sumup,n26

# Lever company slugs (comma-separated)
# Find the slug in: https://jobs.lever.co/{slug}
LEVER_SLUGS=pitch,miro,remote,typeform,revolut

# SQLite DB path (relative to project root)
DB_PATH=./jobs.db

# Optional: email digest via nodemailer (SMTP)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=you@gmail.com

# Optional: concurrency limit for LLM extraction calls
LLM_CONCURRENCY=3

# Optional: max jobs to extract per run (safety limit)
MAX_JOBS_PER_RUN=50
